# Copie para .env e preencha

# Backend LLM: claude | ollama | offline
JARVIS_BACKEND=claude

# Chave da API Anthropic (necessária se JARVIS_BACKEND=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Modelo Ollama (necessário se JARVIS_BACKEND=ollama)
# Execute: ollama pull llama3.2
JARVIS_OLLAMA_MODEL=llama3.2
