# Copie para .env e preencha

# Backend LLM: claude | ollama | offline
JARVIS_BACKEND=claude
ANTHROPIC_API_KEY=sk-ant-...
JARVIS_OLLAMA_MODEL=llama3.2

# Git DB — caminho local do repositório de dados
JARVIS_DB_PATH=~/.jarvis-db

# Git DB — remote para sync (opcional)
# ex: git@github.com:seu-usuario/jarvis-db-privado.git
JARVIS_DB_REMOTE=

# n8n — URL base da instância (deixe vazio para desativar)
# ex: http://localhost:5678 ou https://n8n.seudominio.com
N8N_BASE_URL=http://localhost:5678
N8N_API_TOKEN=

# Webhooks do n8n (gerados automaticamente a partir do N8N_BASE_URL)
# Só preencha se querer URLs customizadas
N8N_WEBHOOK_SESSAO=
N8N_WEBHOOK_EVENTO=
N8N_WEBHOOK_ALERTA=
N8N_WEBHOOK_MEMORIA=
N8N_WEBHOOK_DRIVE=
